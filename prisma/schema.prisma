generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Registration {
  id                String   @id @default(cuid())
  name              String
  email             String
  phone             String?
  seminarSlug       String
  paymentStatus     String   @default("pending")
  razorpayOrderId   String?  @unique
  razorpayPaymentId String?
  createdAt         DateTime @default(now())

  @@unique([email, seminarSlug])
}

model Question {
  id        String         @id @default(uuid())
  name      String?
  email     String?
  topic     String
  question  String
  answer    String?
  source    String?        @default("website") // website, twitter, webinar, newsletter, admin
  status    QuestionStatus @default(PENDING)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

enum QuestionStatus {
  PENDING
  ANSWERED
  ARCHIVED
}
